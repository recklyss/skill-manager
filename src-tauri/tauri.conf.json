{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri/main/.schemas/desktop-schema.json",
  "productName": "Skill Manager",
  "version": "0.0.1",
  "identifier": "io.mode.skill-manager",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Manager",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": []
  }
}
