{
  "name": "@recklyss/skill-manager",
  "version": "0.0.2",
  "description": "Public macOS/Linux installer wrapper for the skill-manager native release artifact.",
  "license": "MIT",
  "private": false,
  "bin": {
    "skill-manager": "bin/skill-manager.js"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "prepack": "node ../../scripts/sync_public_metadata.mjs --write",
    "postpack": "rm -f LICENSE",
    "postinstall": "node scripts/install.js"
  },
  "files": [
    "LICENSE",
    "release-targets.json",
    "bin",
    "scripts"
  ],
  "homepage": "https://github.com/recklyss/skill-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recklyss/skill-manager.git",
    "directory": "packaging/npm"
  },
  "bugs": {
    "url": "https://github.com/recklyss/skill-manager/issues"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "arm64",
    "x64"
  ]
}
